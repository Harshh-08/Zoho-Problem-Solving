import java.util.ArrayList;

public class Demo{
	public static void main(String[] args){
		ArrayList<Integer> list = new ArrayList<>(); // Autoboxing
		list.add(1);
		list.add(2);
		list.add(3);
		list.add(4);
		list.add(5);
		System.out.println(list); 
		
		
		ArrayList<Character> ch =new ArrayList<>();
		ch.add('A');
		ch.add('B');    
		ch.add('C');
		char c = ch.get(2);     //Unboxing
		System.out.print(c);
	}
}
